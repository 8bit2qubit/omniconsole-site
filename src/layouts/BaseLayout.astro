---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../consts";
import { getLocaleFromUrl, useTranslations, resolveLocale } from "../i18n/utils";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const locale = resolveLocale(Astro.currentLocale ?? getLocaleFromUrl(Astro.url));
const t = useTranslations(locale);
const { title, description = t.site.description, ogImage } = Astro.props;
const pageTitle = title ? `${title} · ${SITE.name}` : `${SITE.name} — ${t.site.tagline}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).href
  : new URL(`${import.meta.env.BASE_URL}og-image.png`.replace(/\/+/g, "/"), Astro.site).href;
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}/logo.png`.replace(/\/+/g, "/")} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}/logo-512.png`.replace(/\/+/g, "/")} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={locale.replace("-", "_")} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="theme-color" content="#0d1117" />
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
