---
import { Icon } from "astro-icon/components";
import { REPO, SITE, XFSET } from "../consts";
import { getLocaleFromUrl, useTranslations, withLocale } from "../i18n/utils";

const locale = Astro.currentLocale ?? getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL;
const logoUrl = `${base}/logo.png`.replace(/\/+/g, "/");

const year = new Date().getFullYear();

const navLinks = [
  { href: withLocale("/", locale, base), label: t.nav.features, anchor: "#features" },
  { href: withLocale("/", locale, base), label: t.nav.gamepad, anchor: "#gamepad" },
  { href: withLocale("/download", locale, base), label: t.nav.download },
  { href: withLocale("/docs/install", locale, base), label: t.nav.docs },
];

const projectLinks = [
  { href: REPO.url, label: "GitHub", external: true },
  { href: REPO.releasesUrl, label: "Releases", external: true },
  { href: XFSET.url, label: XFSET.name, external: true },
];
---
<footer class="mt-20 border-t border-border/70 bg-bg-subtle/40">
  <div class="container-site py-12">
    <div class="grid gap-10 md:grid-cols-4">
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 text-lg font-semibold text-fg">
          <img src={logoUrl} alt="" width="28" height="28" class="h-7 w-7" />
          {SITE.name}
        </div>
        <p class="mt-3 max-w-md text-sm text-fg-muted">{t.footer.tagline}</p>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-fg">{t.footer.nav}</h4>
        <ul class="mt-3 space-y-2 text-sm">
          {navLinks.map((link) => (
            <li>
              <a href={link.anchor ? `${link.href}${link.anchor}` : link.href} class="text-fg-muted hover:text-accent">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-fg">{t.footer.project}</h4>
        <ul class="mt-3 space-y-2 text-sm">
          {projectLinks.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-fg-muted hover:text-accent">
                {link.label}
                <Icon name="lucide:external-link" class="h-3.5 w-3.5 opacity-70" />
              </a>
            </li>
          ))}
          <li>
            <a href={REPO.licenseUrl} target="_blank" rel="noopener" class="text-fg-muted hover:text-accent">
              {t.footer.license}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-start justify-between gap-3 border-t border-border/60 pt-6 text-xs text-fg-subtle sm:flex-row sm:items-center">
      <p>© {year} {SITE.name}. {t.footer.madeBy}
        <a href={`https://github.com/${SITE.author}`} target="_blank" rel="noopener" class="ml-1 text-fg-muted hover:text-accent">
          @{SITE.author}
        </a>.
      </p>
      <p class="text-fg-subtle">GPL-3.0 Licensed</p>
    </div>
  </div>
</footer>
