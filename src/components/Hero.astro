---
import { Icon } from "astro-icon/components";
import { IMG_BASE, LOCALE_IMG_SUFFIX, REPO } from "../consts";
import { getLocaleFromUrl, resolveLocale, useTranslations, withLocale } from "../i18n/utils";

const locale = resolveLocale(Astro.currentLocale ?? getLocaleFromUrl(Astro.url));
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL;
const suffix = LOCALE_IMG_SUFFIX[locale];

const downloadHref = withLocale("/download", locale, base);
const appShotUrl = `${base}${IMG_BASE}/app-settings${suffix}.png`.replace(/\/+/g, "/");
const widgetShotUrl = `${base}${IMG_BASE}/widget-omnicharm${suffix}.png`.replace(/\/+/g, "/");
---
<section class="relative overflow-hidden border-b border-border/50">
  <div
    class="absolute inset-0 -z-10 opacity-[0.35]"
    style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(88,166,255,0.18), transparent 60%), radial-gradient(ellipse 40% 30% at 80% 20%, rgba(163,113,247,0.12), transparent 60%);"
  ></div>

  <div class="container-site pb-16 pt-16 sm:pt-24 md:pb-20 md:pt-28">
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-flex items-center gap-1.5 rounded-full border border-accent/30 bg-accent/10 px-3 py-1 text-xs font-medium text-accent">
        <Icon name="lucide:sparkles" class="h-3.5 w-3.5" />
        {t.hero.eyebrow}
      </span>
      <h1 class="mt-5 text-4xl font-bold leading-[1.05] tracking-tight text-fg sm:text-5xl md:text-6xl">
        {t.hero.title}
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-base text-fg-muted sm:text-lg">
        {t.hero.subtitle}
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href={downloadHref} class="btn-primary">
          <Icon name="lucide:download" class="h-4 w-4" />
          {t.hero.ctaDownload}
        </a>
        <a href={REPO.url} target="_blank" rel="noopener" class="btn-secondary">
          <Icon name="lucide:github" class="h-4 w-4" />
          {t.hero.ctaGitHub}
        </a>
      </div>
    </div>

    <div class="mt-14 flex flex-wrap items-end justify-center gap-4 sm:gap-6">
      <div class="flex flex-col items-center">
        <img
          src={appShotUrl}
          alt={t.hero.screenshotAlt1}
          width="520"
          height="350"
          loading="eager"
          decoding="async"
          class="h-auto max-h-[22rem] w-auto max-w-full rounded-xl border border-border shadow-2xl shadow-accent/10"
        />
        <p class="mt-2 text-xs text-fg-subtle">{t.hero.screenshotCaption1}</p>
      </div>
      <div class="flex flex-col items-center">
        <img
          src={widgetShotUrl}
          alt={t.hero.screenshotAlt2}
          width="380"
          height="350"
          loading="eager"
          decoding="async"
          class="h-auto max-h-[22rem] w-auto max-w-full rounded-xl border border-border shadow-2xl shadow-accent/10"
        />
        <p class="mt-2 text-xs text-fg-subtle">{t.hero.screenshotCaption2}</p>
      </div>
    </div>
  </div>
</section>
