---
import { Icon } from "astro-icon/components";
import { getLocaleFromUrl, useTranslations, withLocale } from "../i18n/utils";

const locale = Astro.currentLocale ?? getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL;

const steps = [t.quickStart.step1, t.quickStart.step2, t.quickStart.step3, t.quickStart.step4];
---
<section class="border-b border-border/50 py-16 md:py-24">
  <div class="container-site">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-fg sm:text-4xl">{t.quickStart.title}</h2>
      <p class="mt-4 text-fg-muted">{t.quickStart.subtitle}</p>
    </div>

    <ol class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {steps.map((step, idx) => (
        <li class="card relative">
          <div class="flex items-center gap-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-accent/15 text-sm font-semibold text-accent">
              {idx + 1}
            </span>
            <h3 class="text-base font-semibold text-fg">{step.title}</h3>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-fg-muted">{step.body}</p>
        </li>
      ))}
    </ol>

    <div class="mt-8 text-center">
      <a href={withLocale("/docs/install", locale, base)} class="btn-secondary">
        {t.quickStart.cta}
        <Icon name="lucide:arrow-right" class="h-4 w-4" />
      </a>
    </div>
  </div>
</section>
