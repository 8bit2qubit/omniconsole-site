---
import { Icon } from "astro-icon/components";
import { getLocaleFromUrl, useTranslations, withLocale } from "../i18n/utils";
import { GAMEPAD_SHORTCUT_IMG, GAMEPAD_MOUSE_MODE_IMG, type Locale } from "../consts";

const locale = (Astro.currentLocale ?? getLocaleFromUrl(Astro.url)) as Locale;
const t = useTranslations(locale);
const g = t.gamepadHighlights;
const base = import.meta.env.BASE_URL;
const docsHref = withLocale("/docs/gamepad", locale, base);
const shortcutImgPath = GAMEPAD_SHORTCUT_IMG[locale] ?? GAMEPAD_SHORTCUT_IMG.en;
const shortcutImg = `${base}${shortcutImgPath}`.replace(/\/+/g, "/");
const mouseModeImg = `${base}${GAMEPAD_MOUSE_MODE_IMG}`.replace(/\/+/g, "/");
---
<section id="gamepad" class="border-b border-border/50 py-16 md:py-24">
  <div class="container-site">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-fg sm:text-4xl">{g.sectionTitle}</h2>
      <p class="mt-4 text-base text-fg-muted sm:text-lg">{g.sectionSubtitle}</p>
    </div>

    <!-- Gamepad Steam Shortcuts -->
    <div class="card mt-12 overflow-hidden p-0">
      <div class="grid gap-0 md:grid-cols-[minmax(0,1.1fr)_minmax(0,1fr)]">
        <div class="flex items-center justify-center bg-bg-subtle/60 p-6 md:p-8">
          <img
            src={shortcutImg}
            alt={g.shortcuts.imageAlt}
            width="963"
            height="538"
            loading="lazy"
            class="h-auto w-full max-w-[560px] rounded-xl border border-border shadow-2xl shadow-accent/10"
          />
        </div>
        <div class="flex flex-col justify-center p-6 md:p-8">
          <div class="flex items-center gap-2 text-accent">
            <Icon name="lucide:gamepad-2" class="h-5 w-5" />
            <span class="text-xs font-semibold uppercase tracking-wide">{t.features.category.gamepad}</span>
          </div>
          <h3 class="mt-2 text-2xl font-bold text-fg">{g.shortcuts.title}</h3>
          <p class="mt-3 text-sm text-fg-muted">{g.shortcuts.description}</p>

          <div class="mt-5 overflow-hidden rounded-lg border border-border/60">
            <table class="w-full text-left text-sm">
              <thead class="bg-bg-subtle/50 text-xs uppercase tracking-wide text-fg-subtle">
                <tr>
                  <th class="px-3 py-2 font-medium">{g.headers.button}</th>
                  <th class="px-3 py-2 font-medium">{g.headers.action}</th>
                </tr>
              </thead>
              <tbody>
                {g.shortcuts.rows.map((r) => (
                  <tr class="border-t border-border/50">
                    <td class="px-3 py-2 font-mono text-fg">{r.button}</td>
                    <td class="px-3 py-2 text-fg">{r.action}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <p class="mt-3 text-xs text-fg-subtle">{g.shortcuts.footnote}</p>
        </div>
      </div>
    </div>

    <!-- Gamepad Mouse Mode -->
    <div class="card mt-8 overflow-hidden p-0">
      <div class="grid gap-0 md:grid-cols-[minmax(0,1fr)_minmax(0,1.1fr)]">
        <div class="order-first flex flex-col justify-center p-6 md:order-last md:p-8">
          <div class="flex items-center gap-2 text-accent">
            <Icon name="lucide:mouse-pointer-2" class="h-5 w-5" />
            <span class="text-xs font-semibold uppercase tracking-wide">{t.features.category.gamepad}</span>
          </div>
          <h3 class="mt-2 text-2xl font-bold text-fg">{g.mouseMode.title}</h3>
          <p class="mt-3 text-sm text-fg-muted">{g.mouseMode.description}</p>

          <div class="mt-5 overflow-hidden rounded-lg border border-border/60">
            <table class="w-full text-left text-sm">
              <thead class="bg-bg-subtle/50 text-xs uppercase tracking-wide text-fg-subtle">
                <tr>
                  <th class="px-3 py-2 font-medium">{g.headers.button}</th>
                  <th class="px-3 py-2 font-medium">{g.headers.action}</th>
                </tr>
              </thead>
              <tbody>
                {g.mouseMode.rows.map((r) => (
                  <tr class="border-t border-border/50">
                    <td class="px-3 py-2 font-mono text-fg">{r.button}</td>
                    <td class="px-3 py-2 text-fg">{r.action}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <p class="mt-3 text-xs text-fg-subtle">{g.mouseMode.footnote}</p>
        </div>
        <div class="flex items-center justify-center bg-bg-subtle/60 p-6 md:p-8">
          <img
            src={mouseModeImg}
            alt={g.mouseMode.imageAlt}
            width="500"
            height="537"
            loading="lazy"
            class="h-auto w-full max-w-[360px] rounded-xl border border-border shadow-2xl shadow-accent/10"
          />
        </div>
      </div>
    </div>

    <div class="mt-8 text-center">
      <a
        href={docsHref}
        class="inline-flex items-center gap-2 text-sm font-medium text-accent hover:text-accent-hover"
      >
        {g.cta}
        <Icon name="lucide:arrow-right" class="h-4 w-4" />
      </a>
    </div>
  </div>
</section>
