---
import { Icon } from "astro-icon/components";
import { getLocaleFromUrl, useTranslations } from "../i18n/utils";

const locale = Astro.currentLocale ?? getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const w = t.what;

const entryIcons = ["lucide:power", "lucide:gamepad-2", "lucide:layout-grid"];
---
<section class="border-b border-border/50 py-16 md:py-24">
  <div class="container-site">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-fg sm:text-4xl">{w.title}</h2>
      <p class="mt-4 text-base text-fg-muted sm:text-lg">{w.body}</p>
    </div>

    <div class="mt-12">
      <h3 class="mb-8 text-center text-xs font-semibold uppercase tracking-widest text-fg-subtle">
        {w.flowTitle}
      </h3>

      <div class="grid items-center gap-6 lg:grid-cols-[minmax(0,1fr)_auto_minmax(0,1.2fr)]">
        <!-- Column 1: three entry cards -->
        <div class="flex flex-col gap-3">
          {w.entries.map((e, i) => (
            <div class="card flex gap-3 p-4">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-accent">
                <Icon name={entryIcons[i]} class="h-5 w-5" />
              </div>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-fg">{e.title}</p>
                <p class="mt-1 text-xs text-fg-muted">{e.body}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Connector: 3 lines → diamond (desktop) / single arrow (mobile) -->
        <div class="flex items-center justify-center text-fg-subtle">
          <Icon name="lucide:arrow-down" class="h-6 w-6 lg:hidden" />
          <div class="hidden items-center gap-2 lg:flex">
            <div class="flex flex-col gap-[2.75rem]">
              <span class="h-px w-10 bg-border"></span>
              <span class="h-px w-10 bg-border"></span>
              <span class="h-px w-10 bg-border"></span>
            </div>
            <div class="flex h-12 w-12 rotate-45 items-center justify-center rounded-md border border-border bg-bg-subtle/50">
              <Icon name="lucide:git-branch" class="h-5 w-5 -rotate-45 text-accent" />
            </div>
            <Icon name="lucide:arrow-right" class="h-5 w-5" />
          </div>
        </div>

        <!-- Column 3: two branch results -->
        <div class="flex flex-col gap-3">
          <div class="rounded-xl border border-success/40 bg-success/5 p-4">
            <div class="flex items-center gap-2 text-success">
              <Icon name="lucide:check-circle-2" class="h-5 w-5" />
              <span class="text-xs font-semibold uppercase tracking-wide">{w.decisionInFse}</span>
            </div>
            <p class="mt-1.5 text-sm text-fg">{w.resultInFse}</p>
          </div>
          <div class="rounded-xl border border-warning/40 bg-warning/5 p-4">
            <div class="flex items-center gap-2 text-warning">
              <Icon name="lucide:alert-circle" class="h-5 w-5" />
              <span class="text-xs font-semibold uppercase tracking-wide">{w.decisionOutFse}</span>
            </div>
            <p class="mt-1.5 text-sm text-fg">{w.resultOutFse}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
