---
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  icon: string;
  description: string;
}

const { title, icon, description } = Astro.props;
---
<div class="card h-full">
  <div class="inline-flex rounded-lg bg-accent/10 p-2.5 text-accent">
    <Icon name={icon} class="h-5 w-5" />
  </div>
  <h3 class="mt-4 text-base font-semibold text-fg">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-fg-muted">{description}</p>
</div>
